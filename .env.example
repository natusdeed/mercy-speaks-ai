# =============================================================================
# Mercy Speaks AI — Environment Variables
# Copy to .env.local and fill in values. Never commit .env.local (see .gitignore).
# =============================================================================

# -----------------------------------------------------------------------------
# Public (exposed to browser — no secrets; use VITE_* for Vite, NEXT_PUBLIC_* for Next.js)
# -----------------------------------------------------------------------------
# Optional: Full app URL for links in emails/SMS (e.g. https://mercy-speaks-ai.vercel.app)
# VITE_APP_URL=
# NEXT_PUBLIC_APP_URL=

# -----------------------------------------------------------------------------
# Server — Chat / AI (server-side only; never expose to client)
# -----------------------------------------------------------------------------
# OpenAI API key for the site chatbot (POST /api/chat).
# Get it: https://platform.openai.com/api-keys
# Required on Vercel: set in Project Settings → Environment Variables (Production + Preview) or chat shows "Connection issue".
OPENAI_API_KEY=

# Legacy (optional): Anthropic key if you use a separate Claude endpoint.
# ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# Server — Twilio (voice + SMS)
# -----------------------------------------------------------------------------
# From Twilio Console: https://console.twilio.com/ (Account SID, Auth Token, Phone Number)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# -----------------------------------------------------------------------------
# Server — Vapi (voice agent)
# -----------------------------------------------------------------------------
# From Vapi dashboard: https://dashboard.vapi.ai/ (API key; phone/SIP if applicable)
VAPI_API_KEY=
# Optional: Webhook secret to verify Vapi requests (if supported)
# VAPI_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Server — Database (Missed Revenue Dashboard, leads, calls)
# -----------------------------------------------------------------------------
# Postgres connection string. Get from Vercel Postgres, Neon, Supabase, etc.
# POSTGRES_URL=
# Or common alias:
# DATABASE_URL=

# -----------------------------------------------------------------------------
# Server — Integrations (optional)
# -----------------------------------------------------------------------------
# Cal.com or Calendly — appointment booking tool
# CALCOM_API_KEY=
# CALENDLY_API_KEY=
# CALENDLY_EVENT_TYPE_URI=

# CRM webhook — POST lead/outcome to your CRM
# CRM_WEBHOOK_URL=

# Email (Resend, SendGrid, etc.) — confirmations and notifications
# RESEND_API_KEY=
# EMAIL_FROM=
# Optional: where to send lead notifications (default: don@mercyspeaksdigital.com)
# LEAD_NOTIFICATION_EMAIL=

# Link used in missed-call SMS and emails (e.g. booking or contact page)
# BOOKING_LINK=

# -----------------------------------------------------------------------------
# Booking URL — used by all primary CTAs, /book-demo page, and chatbot
# -----------------------------------------------------------------------------
# Primary demo booking (Cal.com). Set both for full coverage:
# - BOOKING_URL: server (API, chatbot, business-context)
# - VITE_BOOKING_URL: client (Vite exposes only VITE_* at build time)
# Default in code: https://cal.com/natusdeed/free-ai-receptionist-demo
# On Vercel: set OPENAI_API_KEY (required for /api/chat), BOOKING_URL, and VITE_BOOKING_URL
# in Project Settings → Environment Variables (Production, Preview, Development).
BOOKING_URL=https://cal.com/natusdeed/free-ai-receptionist-demo
VITE_BOOKING_URL=https://cal.com/natusdeed/free-ai-receptionist-demo

# -----------------------------------------------------------------------------
# Multi-tenant widget (optional) — Supabase + fallback env
# -----------------------------------------------------------------------------
# Supabase: project URL and service role key (for tenants, leads, conversations).
# Get from Supabase Dashboard → Settings → API. Use service role for serverless.
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_KEY=eyJ...

# Fallback when Supabase not set: single tenant from env (e.g. your own site).
# MERCY_TENANT_ID=default
# Comma-separated allowed domains (embedding site + widget host for iframe). Include your app domain (e.g. localhost, YOUR_DOMAIN) so the iframe can load config/chat.
# MERCY_WIDGET_DOMAINS=localhost,127.0.0.1,mercy-speaks-ai.vercel.app,www.mercyspeaks.ai
# Optional: when set, script must include data-key with this value; API rejects mismatched key.
# MERCY_WIDGET_PUBLIC_KEY=
# MERCY_WIDGET_NAME=Mercy Speaks Digital
# MERCY_WIDGET_PRIMARY_COLOR=#06b6d4
# MERCY_WIDGET_ACCENT_COLOR=#8b5cf6
# MERCY_BOOKING_URL=https://cal.com/natusdeed/free-ai-receptionist-demo
# MERCY_WIDGET_GREETING=Hi! I'm Mercy AI. How can I help?
# MERCY_WIDGET_SYSTEM_PROMPT=You are Mercy AI, a professional assistant for Mercy Speaks Digital...

# -----------------------------------------------------------------------------
# Mercy AI Dashboard (internal admin — server-only secrets)
# -----------------------------------------------------------------------------
# How it works: one allowed work email + one shared password + HMAC session cookie.
# No Supabase Auth for dashboard login, no public signup, no user database for sign-in.
#
# SETUP (local):
#   1. From repo root:  npm run dashboard:bootstrap -- your@email.com
#   2. Copy the three printed lines into my-app/.env.local (create the file if needed).
#   3. Restart: npm run dev
#   4. Open the dashboard login route; use the same email and the generated MERCY_DASHBOARD_PASSWORD.
#
# SETUP (Vercel):
#   1. Run bootstrap locally (same command) to generate values — or use a password manager + openssl rand -hex 32 for MERCY_DASHBOARD_SESSION_SECRET.
#   2. Vercel → your project → Settings → Environment Variables
#   3. Add MERCY_DASHBOARD_ADMIN_EMAIL, MERCY_DASHBOARD_PASSWORD, MERCY_DASHBOARD_SESSION_SECRET
#      for Production (and Preview if previews should access the dashboard).
#   4. Redeploy.
#
# Designated work email (must match the login form; comparison is case-insensitive).
MERCY_DASHBOARD_ADMIN_EMAIL=
# Shared password for MVP sign-in (canonical name). Generate with: npm run dashboard:bootstrap -- you@company.com
MERCY_DASHBOARD_PASSWORD=
# Optional alias for the same value as MERCY_DASHBOARD_PASSWORD (if you prefer the name).
# MERCY_DASHBOARD_ADMIN_PASSWORD=
# HMAC secret for signed session tokens (bootstrap prints a hex value, or: openssl rand -hex 32)
MERCY_DASHBOARD_SESSION_SECRET=
# Optional: super_admin | admin | sales_rep | support | client_view (default: super_admin)
# MERCY_DASHBOARD_DEFAULT_ROLE=super_admin

# Optional: when set, dashboard-created leads use this tenants.id (must exist if you keep NOT NULL elsewhere)
# MERCY_DASHBOARD_DEFAULT_TENANT_ID=demo

# -----------------------------------------------------------------------------
# Widget demo tenant (no DB required)
# -----------------------------------------------------------------------------
# For local/dev MVP you can use the built-in tenant:
# - tenantId=demo
# - key=demo_public_key
# It allows origins: localhost, 127.0.0.1, *.vercel.app, mercyspeaksdigital.com